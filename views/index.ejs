<%- include('./partials/header') %>

<div class="row justify-content-center">
  <div class="col-lg-8">
    <div class="text-center">
      <div class="mb-5">
        <i class="fas fa-tasks fa-5x text-primary mb-4"></i>
        <h1 class="display-4 fw-bold mb-3">TaskFlow</h1>
        <p class="lead text-muted mb-4">
          A Modern Task Management Solution
        </p>
      </div>

      <div class="row mb-5">
        <div class="col-md-6 mb-3">
          <div class="card h-100 border-0 shadow-sm">
            <div class="card-body">
              <i class="fas fa-lock-open fa-3x text-success mb-3"></i>
              <h5 class="card-title">Easy Authentication</h5>
              <p class="card-text text-muted">
                Secure registration and login with encrypted passwords
              </p>
            </div>
          </div>
        </div>
        <div class="col-md-6 mb-3">
          <div class="card h-100 border-0 shadow-sm">
            <div class="card-body">
              <i class="fas fa-list-check fa-3x text-info mb-3"></i>
              <h5 class="card-title">Task Management</h5>
              <p class="card-text text-muted">
                Create, edit, and delete tasks with ease
              </p>
            </div>
          </div>
        </div>
        <div class="col-md-6 mb-3">
          <div class="card h-100 border-0 shadow-sm">
            <div class="card-body">
              <i class="fas fa-chart-bar fa-3x text-warning mb-3"></i>
              <h5 class="card-title">Task Statistics</h5>
              <p class="card-text text-muted">
                Track your progress with detailed statistics
              </p>
            </div>
          </div>
        </div>
        <div class="col-md-6 mb-3">
          <div class="card h-100 border-0 shadow-sm">
            <div class="card-body">
              <i class="fas fa-mobile-alt fa-3x text-danger mb-3"></i>
              <h5 class="card-title">Responsive Design</h5>
              <p class="card-text text-muted">
                Works perfectly on all devices and screen sizes
              </p>
            </div>
          </div>
        </div>
      </div>

      <div class="d-grid gap-2 d-sm-flex justify-content-sm-center">
        <a href="/auth/login" class="btn btn-primary btn-lg px-4">
          <i class="fas fa-sign-in-alt"></i> Login
        </a>
        <a href="/auth/register" class="btn btn-success btn-lg px-4">
          <i class="fas fa-user-plus"></i> Register
        </a>
      </div>
    </div>
  </div>
</div>

<%- include('./partials/footer') %>
