<%- include('./partials/header') %>

<div class="row">
  <div class="col-12">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <div>
        <h1 class="display-6">
          <i class="fas fa-tasks text-primary"></i> My Tasks
        </h1>
        <p class="text-muted">Welcome back, <strong><%= user %></strong>!</p>
      </div>
      <a href="/tasks/add" class="btn btn-primary btn-lg">
        <i class="fas fa-plus-circle"></i> New Task
      </a>
    </div>

    <div class="row mb-4">
      <div class="col-md-4">
        <div class="card border-left-primary">
          <div class="card-body">
            <h5 class="card-title text-muted">Total Tasks</h5>
            <h2 class="text-primary"><%= tasks.length %></h2>
          </div>
        </div>
      </div>
      <div class="col-md-4">
        <div class="card border-left-success">
          <div class="card-body">
            <h5 class="card-title text-muted">Completed</h5>
            <h2 class="text-success"><%= tasks.filter(t => t.status === 'completed').length %></h2>
          </div>
        </div>
      </div>
      <div class="col-md-4">
        <div class="card border-left-warning">
          <div class="card-body">
            <h5 class="card-title text-muted">Pending</h5>
            <h2 class="text-warning"><%= tasks.filter(t => t.status === 'pending').length %></h2>
          </div>
        </div>
      </div>
    </div>

    <div class="card shadow-sm border-0">
      <div class="card-body">
        <% if (tasks.length === 0) { %>
          <div class="text-center py-5">
            <i class="fas fa-inbox fa-3x text-muted mb-3"></i>
            <h4 class="text-muted">No tasks yet</h4>
            <p class="text-muted mb-3">Create your first task to get started</p>
            <a href="/tasks/add" class="btn btn-primary">
              <i class="fas fa-plus-circle"></i> Create Task
            </a>
          </div>
        <% } else { %>
          <div class="table-responsive">
            <table class="table table-hover mb-0">
              <thead class="table-light">
                <tr>
                  <th>Task Title</th>
                  <th>Description</th>
                  <th>Status</th>
                  <th>Actions</th>
                </tr>
              </thead>
              <tbody>
                <% tasks.forEach(task => { %>
                  <tr class="<%= task.status === 'completed' ? 'table-success' : '' %>">
                    <td>
                      <strong>
                        <% if (task.status === 'completed') { %>
                          <s><%= task.title %></s>
                        <% } else { %>
                          <%= task.title %>
                        <% } %>
                      </strong>
                    </td>
                    <td>
                      <span class="text-muted text-truncate d-block" style="max-width: 300px;">
                        <%= task.description || 'No description' %>
                      </span>
                    </td>
                    <td>
                      <span class="badge bg-<%= task.status === 'completed' ? 'success' : 'warning' %> text-dark">
                        <%= task.status.toUpperCase() %>
                      </span>
                    </td>
                    <td>
                      <div class="btn-group" role="group">
                        <!-- Toggle Status Button -->
                        <a 
                          href="/tasks/toggle/<%= task.id %>" 
                          class="btn btn-sm btn-outline-secondary" 
                          title="Toggle task status"
                        >
                          <i class="fas fa-check-circle"></i>
                        </a>
                        
                        <!-- Edit Button -->
                        <a 
                          href="/tasks/edit/<%= task.id %>" 
                          class="btn btn-sm btn-outline-primary"
                          title="Edit task"
                        >
                          <i class="fas fa-edit"></i>
                        </a>
                        
                        <!-- Delete Button -->
                        <a 
                          href="/tasks/delete/<%= task.id %>" 
                          class="btn btn-sm btn-outline-danger"
                          onclick="return confirm('Are you sure you want to delete this task?');"
                          title="Delete task"
                        >
                          <i class="fas fa-trash"></i>
                        </a>
                      </div>
                    </td>
                  </tr>
                <% }); %>
              </tbody>
            </table>
          </div>
        <% } %>
      </div>
    </div>
  </div>
</div>

<%- include('./partials/footer') %>
